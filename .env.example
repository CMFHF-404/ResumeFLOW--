# 前端 API 地址
VITE_API_BASE_URL=https://your-backend-domain.zeabur.app

# Logto 配置
VITE_LOGTO_ENDPOINT=https://your-logto-tenant.logto.app
VITE_LOGTO_APP_ID=your_logto_app_id
VITE_LOGTO_REDIRECT_URI=https://your-frontend-domain.zeabur.app/callback
