# Umami 配置
VITE_UMAMI_HOST=https://your-umami-domain.example.com
VITE_UMAMI_WEBSITE_ID=your-umami-website-id

# PostHog 配置
VITE_PUBLIC_POSTHOG_KEY=your_posthog_key
