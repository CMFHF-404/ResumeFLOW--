DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>
LOGTO_ISSUER=https://<your-tenant-id>.logto.app/oidc
LOGTO_APP_ID=your_logto_spa_app_id
LOGTO_JWKS_TTL_SECONDS=3600
FRONTEND_ORIGIN=http://localhost:5173
EXPORT_SNAPSHOT_TTL_SECONDS=300
EXPORT_RENDER_TIMEOUT_SECONDS=45
EXPORT_TOKEN_SECRET=your_export_token_secret
REDEMPTION_CODE_ENCRYPTION_KEY=your_strong_redemption_code_encryption_key
AI_ROUTE_PROFILE=hybrid_gemini_aifast
# AIFAST/OpenAI-compatible lane for ordinary resume parsing. AI_FAST_* falls back to AI_* when omitted.
AI_API_KEY=your_aifast_or_gray_release_api_key
AI_BASE_URL=https://your-aifast-compatible-endpoint.example.com/v1
AI_MODEL=aifast-default
AI_FAST_API_KEY=your_aifast_api_key
AI_FAST_BASE_URL=https://your-aifast-compatible-endpoint.example.com/v1
AI_FAST_MODEL=aifast-resume-parser
AI_DEDUPE_ENABLED=true
AI_DEDUPE_MODEL=aifast-resume-parser
AI_DEDUPE_MAX_CANDIDATES=24
AI_TIMEOUT_SECONDS=300
# Qwen gray-release route. Only used as primary when AI_ROUTE_PROFILE=qwen_primary.
AI_RESPONSES_BASE_URL=https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1
# Gemini is the default generation and thinking lane for hybrid_gemini_aifast and gemini_primary.
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash
AI_THINKING_BUDGET_JD_ANALYSIS=1024
AI_THINKING_BUDGET_POLISH=1024
AI_THINKING_BUDGET_BOSS_GREETING=0
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=your_posthog_project_id
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your_app_secret
