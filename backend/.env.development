# 开发环境配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resumeflow
LOGTO_ISSUER=https://stzo1l.logto.app/oidc
LOGTO_AUDIENCE=https://api.elephant-resume.com
ENABLE_DEV_AUTH_BYPASS=false

# AI 服务配置（请替换为实际 Key）
AI_API_KEY=<your-ai-api-key>
AI_BASE_URL=https://www.packyapi.com/v1
AI_MODEL=gemini-3-flash-preview

# CORS 配置（本地开发默认端口）
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# PostHog 分析配置（开发默认关闭）
POSTHOG_ENABLED=false
POSTHOG_API_KEY=<your-posthog-api-key>
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_ID=
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook
